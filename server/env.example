# Task Manager 環境変数テンプレート
# このファイルを .env にコピーして使用してください

# JWT秘密鍵（本番環境では強力なランダム文字列を使用）
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production-256-bits

# CORS許可オリジン（カンマ区切りで複数指定可能）
# 開発環境: * で全て許可
# 本番環境: https://yourdomain.com,https://app.yourdomain.com
ALLOWED_ORIGINS=*

# データベースパス（Docker内では /app/data/tasks.db）
DATABASE_PATH=./data/tasks.db

# サーバーポート
PORT=8080

# SMTPサーバー設定（MailHog用）
SMTP_HOST=mailhog
SMTP_PORT=1025
MAIL_FROM=noreply@taskmanager.local

# デバッグモード（true で詳細ログ出力）
DEBUG=false

